{
  "name": "lilac-editor",
  "version": "0.1.6",
  "description": "Lilac - a smooth, modern WYSIWYG text editor built with pure TypeScript. Zero dependencies, framework-agnostic, with a clean interface and elegant typography.",
  "main": "dist/lilac-editor.umd.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "build:lib": "rm -rf dist && tsc && vite build --mode lib",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "wysiwyg",
    "editor",
    "text-editor",
    "typescript",
    "rich-text",
    "vanilla-js",
    "framework-agnostic",
    "rich-text",
    "contenteditable",
    "zero-dependencies"
  ],
  "author": "Maifee Ul Asad<maifeeulasad@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maifeeulasad/lilac.git"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.45.0",
    "typescript": "^5.0.2"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <21.0.0",
    "react-dom": ">=16.8.0 <21.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/lilac-editor.es.js",
      "require": "./dist/lilac-editor.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  }
}