{
  "name": "lilac-editor",
  "version": "0.2.0",
  "description": "Lilac - a smooth, modern WYSIWYG text editor built with pure TypeScript. Zero dependencies, framework-agnostic, with a clean interface and elegant typography.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsc -w",
    "dev:server": "npx http-server . -p 3000",
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "wysiwyg",
    "editor",
    "text-editor",
    "typescript",
    "rich-text",
    "vanilla-js",
    "framework-agnostic",
    "rich-text",
    "contenteditable",
    "zero-dependencies"
  ],
  "author": "Maifee Ul Asad<maifeeulasad@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maifeeulasad/lilac.git"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "typescript": "^5.0.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}