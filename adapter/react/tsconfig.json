{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "lib": [
            "DOM",
            "ES2020"
        ],
        "jsx": "react-jsx",
        "moduleResolution": "Bundler",
        "strict": true,
        "declaration": true,
        "outDir": "dist",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "**/*"
    ]
}